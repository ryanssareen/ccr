{
  "name": "@ccr/desktop",
  "version": "0.1.1",
  "description": "CCR Electron desktop dashboard",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:main && npm run test:renderer",
    "test:main": "node --test --import tsx 'src/main/**/*.test.ts'",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "package:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_NOTARIZE=1 electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_NOTARIZE=1 electron-builder --mac dmg --arm64",
    "package:mac:release": "electron-vite build && electron-builder --mac dmg --arm64",
    "package:mac:x64": "CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_NOTARIZE=1 electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_NOTARIZE=1 electron-builder --mac dmg --x64",
    "package:mac:release:universal": "electron-vite build && electron-builder --mac dmg --universal"
  },
  "build": {
    "appId": "app.ccr.desktop",
    "productName": "ccr",
    "electronVersion": "41.5.0",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "afterPack": "scripts/adhoc-sign.cjs",
    "afterSign": "scripts/notarize.cjs",
    "dmg": {
      "title": "ccr ${version}",
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@ccr/core": "*",
    "@tanstack/react-virtual": "^3.13.0",
    "cmdk": "^1.1.0",
    "firebase": "^11.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
