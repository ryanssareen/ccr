{
  "name": "@ryanisavibecoder/ccr",
  "version": "1.4.5",
  "description": "Free terminal coding assistant. No API key required — sign up with `ccr login`.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ccr": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js",
    "test": "node --test --import tsx 'src/auth/terminal.test.ts'",
    "prepublishOnly": "cp ../../README.md README.md && npm run -w @ccr/core build && npm run build"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "kleur": "^4.1.5",
    "openai": "^4.79.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@ccr/core": "*",
    "@types/diff": "^5.2.3",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18"
  }
}
