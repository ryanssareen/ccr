{
  "name": "@ccr/desktop-tauri",
  "version": "0.2.0",
  "description": "CCR desktop app (Tauri). Same UI as the Electron build at ~10x smaller bundle.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:dmg": "tauri build --target universal-apple-darwin --bundles dmg",
    "build:msi": "tauri build --bundles msi",
    "build:nsis": "tauri build --bundles nsis",
    "tauri": "tauri",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.2"
  }
}
